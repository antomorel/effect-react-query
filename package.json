{
  "name": "@spiko-tech/effect-react-query",
  "version": "1.1.1",
  "homepage": "https://github.com/spiko-tech/effect-react-query",
  "description": "TanStack Query Effectful hooks",
  "license": "MIT",
  "author": "Antonin MOREL",
  "repository": {
    "type": "git",
    "url": "https://github.com/spiko-tech/effect-react-query.git"
  },
  "workspaces": [
    "example"
  ],
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdx build",
    "test": "tsdx test",
    "test:watch": "tsdx test --watch",
    "lint": "tsdx lint",
    "format": "tsdx format",
    "format:check": "tsdx format --check",
    "typecheck": "tsdx typecheck",
    "changeset:version": "changeset version",
    "changeset:publish": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bunchee": "^6.10.0",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsdx": "^2.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.99.2",
    "effect": "^3.21.1"
  },
  "engines": {
    "node": ">=20"
  }
}